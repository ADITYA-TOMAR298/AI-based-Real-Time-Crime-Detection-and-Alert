# Frontend: set this in Vercel (must be the public Hugging Face Space URL, no trailing slash)
# VITE_API_URL=https://YOUR-SPACE.hf.space

# Backend: set this to your Vercel production URL and any preview URLs that need access.
CORS_ORIGINS=http://localhost:5173,https://YOUR-PROJECT.vercel.app
PUBLIC_API_URL=https://YOUR-SPACE.hf.space

# Hugging Face Spaces has no physical webcam. Set an RTSP URL to enable live detection.
# CAMERA_SOURCE=rtsp://camera-host:554/stream
# PIPELINE_ENABLED=true

# SQLite is for local development only. Use managed Postgres for persistent hosted data.
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DATABASE
